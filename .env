# ──────────────────────────────────────────────────────────────
# FIXR — Environment Variables
# Este arquivo NÃO deve conter valores reais.
# Copie .env.example e preencha em .env.local (nunca commitado)
# ──────────────────────────────────────────────────────────────

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Sentry (monitoramento de erros) — https://sentry.io
VITE_SENTRY_DSN=

# Push Notifications VAPID — gerar com: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=
